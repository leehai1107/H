<UserControl x:Class="ERP.Desktop.Controls.Layout.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP.Desktop.Controls.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="28" d:DesignWidth="800">
    <Border Background="#0F172A">
        <Grid Margin="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="{Binding CurrentPageContext.StatusBrush}" VerticalAlignment="Center"/>
                <TextBlock Margin="10,0,0,0" Foreground="White" FontSize="13" VerticalAlignment="Center" Text="{Binding CurrentPageContext.StatusText}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
