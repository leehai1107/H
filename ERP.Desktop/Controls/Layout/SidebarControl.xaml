<UserControl
    x:Class="ERP.Desktop.Controls.Layout.SidebarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ERP.Desktop.ViewModels">
    <UserControl.Resources>
        <Style x:Key="SidebarButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D415D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border VerticalAlignment="Stretch" Background="#2B2D42">
        <StackPanel>
            <Button Content="🏠 Dashboard" Command="{Binding ShowDashboardCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Dashboard}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="📋 Customer" Command="{Binding ShowCustomerCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Customer}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="📦 Inventory" Command="{Binding ShowInventoryCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Inventory}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🛒 Purchase" Command="{Binding ShowPurchaseCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Purchase}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🏭 Production" Command="{Binding ShowProductionCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Production}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="⚙ Settings" Command="{Binding ShowSettingsCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNavigationItem}" Value="{x:Static vm:NavigationItem.Settings}">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
